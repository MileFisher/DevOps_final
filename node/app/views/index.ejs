<%
  const money = new Intl.NumberFormat('en-US', {
    style: 'currency',
    currency: 'USD',
    maximumFractionDigits: 0
  });
  const totalProducts = products.length;
  const totalValue = products.reduce((sum, product) => sum + Number(product.price || 0), 0);
  const averagePrice = totalProducts ? totalValue / totalProducts : 0;
  const uniqueColors = [...new Set(products.map((product) => (product.color || '').trim().toLowerCase()).filter(Boolean))];
  const highestPrice = products.reduce((max, product) => Math.max(max, Number(product.price || 0)), 0);
  const featuredProducts = products
    .slice()
    .sort((a, b) => Number(b.price || 0) - Number(a.price || 0))
    .slice(0, 3);
%>

<%- include('partials/head', { title: 'DevOps Project Frontend' }) %>

  <main class="page-shell">
    <section class="hero-section">
      <div class="page-grid">
        <header class="site-header">
          <a class="brand" href="/">
            <span class="brand__mark">d</span>
            <span class="brand__text">
              <strong>devops hub</strong>
              <span>project frontend dashboard</span>
            </span>
          </a>
          <nav class="site-nav" aria-label="Primary">
            <a href="#featured">featured</a>
            <a href="#inventory">inventory</a>
          </nav>
          <div class="host-pill">
            <span>version <strong title="<%= appVersion %>"><%= appVersionShort %></strong></span>
            <span>replica <strong><%= hostname %></strong></span>
            <span>source <strong><%= source %></strong></span>
          </div>
        </header>

        <div class="hero-layout">
          <div class="hero-copy">
            <p class="eyebrow">devops project frontend</p>
            <h1>This is the frontend for our DevOps Project.</h1>
            <p class="hero-description">
              This interface keeps your existing CRUD workflow intact while presenting products in a clean, professional layout
              with clear actions, polished inventory cards, and a faster way to manage catalog updates.
            </p>
            <div class="hero-actions">
              <button type="button" class="pill-button pill-button--primary" data-open-product-modal>Add product</button>
              <a class="pill-button pill-button--secondary" href="#inventory">Browse inventory</a>
            </div>
            <div class="stat-row" aria-label="Highlights">
              <article class="stat-card">
                <span class="stat-card__label">catalog size</span>
                <strong><%= totalProducts %></strong>
                <span class="stat-card__meta">live product entries</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__label">average price</span>
                <strong><%= money.format(averagePrice || 0) %></strong>
                <span class="stat-card__meta">across all listings</span>
              </article>
              <article class="stat-card">
                <span class="stat-card__label">color spread</span>
                <strong><%= uniqueColors.length %></strong>
                <span class="stat-card__meta">distinct product tones</span>
              </article>
            </div>
          </div>

          <aside class="hero-panel">
            <div class="hero-panel__top">
              <span class="eyebrow eyebrow--dark">market overview</span>
              <h2>Trusted inventory pulse.</h2>
              <p>Track your most premium listings, total catalog value, and the fastest route into edit mode from one calm, high-contrast surface.</p>
            </div>
            <div class="hero-metrics">
              <div>
                <span>highest ticket</span>
                <strong><%= money.format(highestPrice || 0) %></strong>
              </div>
              <div>
                <span>catalog value</span>
                <strong><%= money.format(totalValue || 0) %></strong>
              </div>
            </div>
            <div class="hero-spotlight-list">
              <% if (featuredProducts.length) { %>
                <% featuredProducts.forEach(function(product, index) { %>
                  <article class="spotlight-item">
                    <span class="spotlight-item__index">0<%= index + 1 %></span>
                    <div>
                      <strong><%= product.name %></strong>
                      <span><%= money.format(Number(product.price || 0)) %> / <%= product.color %></span>
                    </div>
                  </article>
                <% }) %>
              <% } else { %>
                <p class="spotlight-empty">Add your first product to populate the dashboard.</p>
              <% } %>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <section id="featured" class="section section--dark">
      <div class="page-grid">
        <div class="section-heading">
          <p class="eyebrow eyebrow--dark">featured assets</p>
          <h2>Highlighted products in a clean, high-impact layout.</h2>
          <p>Top-priced entries are highlighted in a darker environment so the blue accent and product imagery do the work without visual noise.</p>
        </div>

        <div class="feature-grid">
          <% if (featuredProducts.length) { %>
            <% featuredProducts.forEach(function(product) { %>
              <article class="feature-card">
                <div class="feature-card__media">
                  <img
                    src="<%= product.imageUrl && product.imageUrl.length ? product.imageUrl : '/images/placeholder-80.png' %>"
                    alt="<%= product.name %>"
                  >
                </div>
                <div class="feature-card__body">
                  <span class="feature-card__badge"><%= product.color %></span>
                  <h3><%= product.name %></h3>
                  <p><%= product.description || 'Curated with a clean, trusted presentation and ready for editing at any time.' %></p>
                  <div class="feature-card__footer">
                    <strong><%= money.format(Number(product.price || 0)) %></strong>
                    <button
                      type="button"
                      class="pill-button pill-button--ghost btn-edit"
                      data-id="<%= product.id %>"
                      data-name="<%= product.name %>"
                      data-price="<%= Number(product.price || 0) %>"
                      data-color="<%= product.color %>"
                      data-description="<%= product.description || '' %>"
                      data-image="<%= product.imageUrl || '' %>"
                    >
                      edit
                    </button>
                  </div>
                </div>
              </article>
            <% }) %>
          <% } else { %>
            <article class="feature-empty">
              <h3>No featured products yet.</h3>
              <p>Create a product and it will immediately appear in this section with the updated project styling.</p>
            </article>
          <% } %>
        </div>
      </div>
    </section>

    <section id="inventory" class="section section--light">
      <div class="page-grid">
        <div class="section-heading section-heading--split">
          <div>
            <p class="eyebrow">inventory desk</p>
            <h2>Browse, search, and maintain the full catalog.</h2>
            <p>Everything below is wired to the current Express routes, including add, edit, delete, image upload, and in-memory or Mongo-backed persistence.</p>
          </div>
          <button type="button" class="pill-button pill-button--primary" data-open-product-modal>new listing</button>
        </div>

        <div class="inventory-toolbar">
          <label class="field-shell field-shell--wide" for="inventory-search">
            <span>search</span>
            <input id="inventory-search" type="search" placeholder="Find by product name or description">
          </label>
          <label class="field-shell" for="inventory-color-filter">
            <span>color</span>
            <select id="inventory-color-filter">
              <option value="">All colors</option>
              <% uniqueColors.forEach(function(color) { %>
                <option value="<%= color %>"><%= color %></option>
              <% }) %>
            </select>
          </label>
          <label class="field-shell" for="inventory-sort">
            <span>sort</span>
            <select id="inventory-sort">
              <option value="featured">Featured first</option>
              <option value="price-desc">Price: high to low</option>
              <option value="price-asc">Price: low to high</option>
              <option value="name-asc">Name: A to Z</option>
            </select>
          </label>
        </div>

        <div class="inventory-summary">
          <strong id="inventory-count"><%= totalProducts %> <%= totalProducts === 1 ? 'product' : 'products' %></strong>
          <span>Available to search, edit, and remove in place.</span>
        </div>

        <div id="product-grid" class="product-grid">
          <% if (products.length) { %>
            <% products.forEach(function(product) { %>
              <article
                class="product-card"
                data-product-card
                data-id="<%= product.id %>"
                data-name="<%= product.name %>"
                data-price="<%= Number(product.price || 0) %>"
                data-color="<%= product.color %>"
                data-description="<%= product.description || '' %>"
                data-image="<%= product.imageUrl || '' %>"
              >
                <div class="product-card__media">
                  <img
                    src="<%= product.imageUrl && product.imageUrl.length ? product.imageUrl : '/images/placeholder-80.png' %>"
                    alt="<%= product.name %>"
                  >
                </div>
                <div class="product-card__body">
                  <div class="product-card__head">
                    <span class="product-card__color"><%= product.color %></span>
                    <strong><%= money.format(Number(product.price || 0)) %></strong>
                  </div>
                  <h3><%= product.name %></h3>
                  <p><%= product.description || 'No description yet. Use edit to enrich the product story and visual context.' %></p>
                </div>
                <div class="product-card__footer">
                  <button type="button" class="card-action btn-edit">Edit</button>
                  <button type="button" class="card-action card-action--danger btn-delete">Delete</button>
                </div>
              </article>
            <% }) %>
          <% } %>
        </div>

        <div id="inventory-empty" class="inventory-empty"<%= products.length ? ' hidden' : '' %>>
          <h3>No products match the current view.</h3>
          <p>Try clearing the filters, or add a new listing to grow the catalog.</p>
        </div>
      </div>
    </section>

    <section class="section section--dark section--compact">
      <div class="page-grid">
        <div class="workflow-grid">
          <article class="workflow-card">
            <span class="workflow-card__eyebrow">create</span>
            <h3>Fast onboarding for new listings</h3>
            <p>Use the modal to add a product with image upload, then publish it into the live catalog immediately.</p>
          </article>
          <article class="workflow-card">
            <span class="workflow-card__eyebrow">update</span>
            <h3>Editing stays one click away</h3>
            <p>Every featured card and inventory card can launch the same update flow without leaving the page.</p>
          </article>
          <article class="workflow-card">
            <span class="workflow-card__eyebrow">control</span>
            <h3>Delete with guardrails</h3>
            <p>Destructive actions stay explicit and isolated, keeping the management surface calm and trustworthy.</p>
          </article>
        </div>
      </div>
    </section>
  </main>

  <div class="modal fade" id="productModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
      <div class="modal-content product-modal">
        <form id="product-form">
          <div class="product-modal__header">
            <div>
              <p class="eyebrow">catalog editor</p>
              <h2 id="modalTitle">Add Product</h2>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>

          <div class="product-modal__body">
            <input type="hidden" id="product-id">
            <div class="product-modal__grid">
              <div class="product-modal__preview">
                <img id="img-preview" src="/images/placeholder-80.png" alt="Product preview">
                <p>Upload artwork or product photography. New files replace the current image on save.</p>
              </div>

              <div class="product-modal__fields">
                <label class="field-shell" for="name">
                  <span>name</span>
                  <input id="name" name="name" type="text" required>
                </label>
                <label class="field-shell" for="price">
                  <span>price</span>
                  <input id="price" name="price" type="number" step="0.01" min="0" required>
                </label>
                <label class="field-shell" for="color">
                  <span>color</span>
                  <input id="color" name="color" type="text" required>
                </label>
                <label class="field-shell" for="description">
                  <span>description</span>
                  <textarea id="description" name="description" rows="4"></textarea>
                </label>
                <label class="field-shell" for="imageFile">
                  <span>image</span>
                  <input id="imageFile" name="imageFile" type="file" accept="image/*">
                </label>
                <input type="hidden" id="imageUrl" name="imageUrl">
                <p id="form-status" class="form-status" aria-live="polite"></p>
              </div>
            </div>
          </div>

          <div class="product-modal__footer">
            <button type="button" class="pill-button pill-button--secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" id="modal-save" class="pill-button pill-button--primary">Save product</button>
          </div>
        </form>
      </div>
    </div>
  </div>

<%- include('partials/footer') %>
